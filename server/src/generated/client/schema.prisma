generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                   String                @id @default(uuid())
  name                 String
  email                String                @unique
  phone                String
  address              String
  logo                 String?
  status               OrganizationStatus    @default(active)
  licenseId            String?
  licenseExpiry        DateTime?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  sessions             AdmissionSession[]
  announcements        Announcement[]
  attendances          Attendance[]
  auditLogs            AuditLog[]
  branches             Branch[]
  ceoPanels            CeoPanel[]
  complaints           Complaint[]
  credentialRequests   CredentialRequest[]
  departments          Department[]
  designations         Designation[]
  editDeleteRequests   EditDeleteRequest[]
  employees            Employee[]
  employeeProfiles     EmployeeProfile[]
  enrollments          Enrollment[]
  escalations          Escalation[]
  escalationLogs       EscalationLog[]
  expenseClaims        ExpenseClaim[]
  feeStructures        FeeStructure[]
  gstSettings          GSTSetting[]
  hrSettings           HRSettings?
  holidays             Holiday[]
  incentiveStructures  IncentiveStructure[]
  internalMarks        InternalMark[]
  invoices             Invoice[]
  leads                Lead[]
  leaveAllocations     LeaveAllocation[]
  leaveRequests        LeaveRequest[]
  notifications        Notification[]
  license              License?              @relation(fields: [licenseId], references: [id])
  payments             PaymentEntry[]
  payrolls             Payroll[]
  payrollBatches       PayrollBatch[]
  polls                Poll[]
  programs             Program[]
  programAllocations   ProgramAllocation[]
  programFeeStructures ProgramFeeStructure[]
  referralLinks        ReferralLink[]
  reregRules           ReregRule[]
  salaryConfigs        SalaryConfig[]
  sessionReqs          SessionRequest[]
  students             Student[]
  studyCenters         StudyCenter[]
  studyCenterInvites   StudyCenterInvite[]
  centerWallets        StudyCenterWallet[]
  subDepartments       SubDepartment[]
  targets              Target[]
  tasks                Task[]
  universities         University[]
  authFees             UniversityAuthFee[]
  users                User[]
  vacancies            Vacancy[]
  walletTopUps         WalletTopUp[]
  programMaterials     ProgramMaterial[]

  @@index([status])
}

model License {
  id             String         @id @default(uuid())
  name           String
  type           LicenseType
  features       Json           @default("[]")
  maxUsers       Int            @default(10)
  maxStorage     Int            @default(1024)
  durationMonths Int            @default(12)
  price          Float
  status         String         @default("active")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizations  Organization[]
}

model Department {
  id                 String             @id @default(uuid())
  organizationId     String
  name               String
  type               DepartmentType
  subType            DepartmentSubType?
  parentDepartmentId String?
  managerId          String?
  features           Json               @default("[]")
  permissions        Json               @default("[]")
  status             String             @default("active")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  announcements      Announcement[]
  opsBranch          Branch?            @relation("BranchOpsDept")
  salesBranch        Branch?            @relation("BranchSalesDept")
  manager            User?              @relation("DepartmentManager", fields: [managerId], references: [id])
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentDepartment   Department?        @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[]       @relation("DepartmentHierarchy")
  designations       Designation[]
  leaveRequests      LeaveRequest[]
  subDepartments     SubDepartment[]
  targets            Target[]
  tasks              Task[]
  users              User[]             @relation("UserToDepartment")
  vacancies          Vacancy[]
  assistantManagers  User[]             @relation("AssistantManagers")

  @@index([organizationId, type])
  @@index([organizationId, status])
}

model User {
  id                            String                @id @default(uuid())
  userId                        String?               @unique
  organizationId                String?
  departmentId                  String?
  additionalDepartmentIds       Json?                 @default("[]")
  branchId                      String?
  subDepartmentId               String?
  ceoPanelId                    String?
  studyCenterId                 String?
  universityId                  String?
  email                         String                @unique
  password                      String
  name                          String
  role                          UserRole
  avatar                        String?
  phone                         String?
  designation                   String?
  reportingTo                   String?
  status                        UserStatus            @default(active)
  lastLogin                     DateTime?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  approvedSessions              AdmissionSession[]    @relation("SessionApprovedBy")
  createdSessions               AdmissionSession[]    @relation("SessionCreatedBy")
  postedAnnouncements           Announcement[]
  attendances                   Attendance[]
  auditLogs                     AuditLog[]
  managedBranch                 Branch?               @relation("BranchManager")
  ceoPanel                      CeoPanel?
  complaints                    Complaint[]
  credentialResponder           CredentialRequest[]   @relation("CredentialResponder")
  credentialRequester           CredentialRequest[]   @relation("CredentialRequester")
  managedDepartments            Department[]          @relation("DepartmentManager")
  editDeleteResponder           EditDeleteRequest[]   @relation("EditDeleteResponder")
  editDeleteRequester           EditDeleteRequest[]   @relation("EditDeleteRequester")
  employeeProfile               Employee?
  employeeProfileDetail         EmployeeProfile?
  deptReviewedEnrollments       Enrollment[]          @relation("DeptReviewedBy")
  financeReviewedEnrollments    Enrollment[]          @relation("FinanceReviewedBy")
  universityReviewedEnrollments Enrollment[]          @relation("UniversityReviewedBy")
  salesLedEnrollments           Enrollment[]          @relation("SalesUserEnrollments")
  deptAdminEscalations          Escalation[]          @relation("EscalationDeptAdmin")
  employeeEscalations           Escalation[]          @relation("EscalationEmployee")
  handledEscalations            Escalation[]          @relation("EscalationHandledBy")
  resolvedEscalations           Escalation[]          @relation("EscalatedResolvedBy")
  approvedExpenseClaims         ExpenseClaim[]        @relation("ExpenseApprovedBy")
  expenseClaims                 ExpenseClaim[]        @relation("EmployeeExpenses")
  createdGstSettings            GSTSetting[]          @relation("GstSettingCreatedBy")
  approvedIncentives            IncentiveStructure[]  @relation("IncentiveApprovedBy")
  createdIncentives             IncentiveStructure[]  @relation("IncentiveCreatedBy")
  enteredMarks                  InternalMark[]        @relation("MarkEnteredBy")
  referredLeads                 Lead[]                @relation("LeadReferredBy")
  createdLeaveAllocations       LeaveAllocation[]     @relation("LeaveAllocationCreatedBy")
  leaveAllocations              LeaveAllocation[]
  deptApprovedLeaves            LeaveRequest[]        @relation("DeptApprovedBy")
  leaveRequests                 LeaveRequest[]        @relation("EmployeeLeaves")
  hrApprovedLeaves              LeaveRequest[]        @relation("HrApprovedBy")
  notifications                 Notification[]
  receivedPayments              PaymentEntry[]        @relation("PaymentReceivedBy")
  confirmedPayrolls             Payroll[]             @relation("PayrollConfirmedBy")
  payrolls                      Payroll[]             @relation("EmployeePayroll")
  financeApprovedPayrolls       Payroll[]             @relation("PayrollFinanceApprovedBy")
  processedPayrolls             Payroll[]             @relation("PayrollProcessedBy")
  transferredPayrolls           Payroll[]             @relation("PayrollTransferredBy")
  batchApproved                 PayrollBatch[]        @relation("BatchApprovedBy")
  batchRejected                 PayrollBatch[]        @relation("BatchRejectedBy")
  batchTransferred              PayrollBatch[]        @relation("BatchTransferredBy")
  createdPolls                  Poll[]                @relation("PollCreatedBy")
  programAllocations            ProgramAllocation[]   @relation("AllocatedBy")
  createdProgramFees            ProgramFeeStructure[] @relation("ProgramFeeCreatedBy")
  referralLink                  ReferralLink?
  salaryApproved                SalaryConfig[]        @relation("SalaryApprovedBy")
  salaryCreated                 SalaryConfig[]        @relation("SalaryCreatedBy")
  salaryConfig                  SalaryConfig?         @relation("UserSalaryConfig")
  approvedRequests              SessionRequest[]      @relation("RequestApprovedBy")
  sessionRequests               SessionRequest[]
  studentProfile                Student?
  referredStudents              Student[]             @relation("StudentReferredBy")
  financeApprovedCenters        StudyCenter[]         @relation("FinanceApprovedBy")
  referredStudyCenters          StudyCenter[]         @relation("ReferredBy")
  verifiedStudyCenters          StudyCenter[]         @relation("VerifiedBy")
  studyCenterInvites            StudyCenterInvite[]   @relation("InviteReferredBy")
  managedSubDepartments         SubDepartment[]       @relation("SubDeptManager")
  targets                       Target[]              @relation("TargetEmployee")
  assignedTasks                 Task[]                @relation("AssignedTasks")
  createdTasks                  Task[]                @relation("CreatedTasks")
  escalatedTasks                Task[]                @relation("EscalatedTasks")
  configuredAuthFees            UniversityAuthFee[]   @relation("AuthFeeConfiguredBy")
  branch                        Branch?               @relation(fields: [branchId], references: [id])
  department                    Department?           @relation("UserToDepartment", fields: [departmentId], references: [id])
  organization                  Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager                       User?                 @relation("ReportingChain", fields: [reportingTo], references: [id])
  subordinates                  User[]                @relation("ReportingChain")
  studyCenter                   StudyCenter?          @relation("CenterAdmin", fields: [studyCenterId], references: [id])
  subDepartment                 SubDepartment?        @relation(fields: [subDepartmentId], references: [id])
  university                    University?           @relation("UniversityAdmin", fields: [universityId], references: [id])
  verifiedWalletTopUps          WalletTopUp[]         @relation("TopUpVerifiedBy")
  assistantManagedDepartments   Department[]          @relation("AssistantManagers")
  designations                  Designation[]         @relation("DesignationFilledBy")
  uploadedMaterials             ProgramMaterial[]     @relation("MaterialUploadedBy")

  @@index([organizationId, role])
  @@index([departmentId])
}

model Employee {
  id             String       @id @default(uuid())
  userId         String       @unique
  organizationId String
  employeeId     String       @unique
  joinDate       DateTime     @default(now())
  salary         Float?
  vacancyId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
}

model Task {
  id               String           @id @default(uuid())
  organizationId   String
  title            String
  description      String
  assignedTo       String
  createdBy        String
  departmentId     String?
  targetDate       DateTime?
  priority         TaskPriority     @default(medium)
  status           TaskStatus       @default(pending)
  deadline         DateTime
  completedAt      DateTime?
  evidence         Json             @default("[]")
  remarks          String?
  escalatedTo      String?
  escalatedAt      DateTime?
  escalationStatus EscalationStatus @default(none)
  gracePeriodEnd   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  escalations      Escalation[]
  assignee         User             @relation("AssignedTasks", fields: [assignedTo], references: [id])
  assigner         User             @relation("CreatedTasks", fields: [createdBy], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  escalatedUser    User?            @relation("EscalatedTasks", fields: [escalatedTo], references: [id])
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assignedTo, status])
  @@index([organizationId, departmentId])
  @@index([deadline, status])
}

model Attendance {
  id               String           @id @default(uuid())
  employeeId       String
  organizationId   String
  date             DateTime
  status           AttendanceStatus
  checkIn          DateTime?
  checkOut         DateTime?
  checkInLocation  Json?
  checkOutLocation Json?
  isLate           Boolean          @default(false)
  lateMinutes      Int              @default(0)
  workingHours     Float            @default(0)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [employeeId], references: [id])
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, date])
  @@index([isLate])
}

model University {
  id                String              @id @default(uuid())
  organizationId    String
  subDepartmentId   String?
  name              String
  code              String
  address           String?
  contact           String?
  country           String?
  status            String              @default("active")
  admissionSessions AdmissionSession[]
  programs          Program[]
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authFees          UniversityAuthFee[]
  admins            User[]              @relation("UniversityAdmin")
  assignedSubDepts  SubDepartment[]     @relation("SubDeptToUniversity")
  allowedBranches   Branch[]            @relation("UniversityToBranch")
  studyCenters      StudyCenter[]       @relation("UniversityToStudyCenter")

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Program {
  id                  String               @id @default(uuid())
  universityId        String
  organizationId      String
  subDepartmentId     String?
  name                String
  code                String
  courseType          CourseType           @default(OnlineDegree)
  duration            Int
  hasSemesters        Boolean              @default(false)
  semesters           Json                 @default("[]")
  status              String               @default("active")
  admissionSessions   AdmissionSession[]
  enrollments         Enrollment[]
  feeStructure        FeeStructure?
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  university          University           @relation(fields: [universityId], references: [id])
  programAllocations  ProgramAllocation[]
  programFeeStructure ProgramFeeStructure?
  reregRules          ReregRule[]
  students            Student[]
  studyCenters        StudyCenter[]        @relation("ProgramToStudyCenter")
  assignedSubDepts    SubDepartment[]      @relation("SubDeptToProgram")
  materials           ProgramMaterial[]

  @@index([universityId])
  @@index([organizationId])
}

model StudyCenter {
  id                     String              @id @default(uuid())
  organizationId         String
  name                   String
  code                   String
  address                String?
  contact                String?
  email                  String?
  city                   String?
  state                  String?
  status                 String              @default("pending_verification")
  universityIds          String[]
  programIds             String[]
  pendingDocuments       Json                @default("[]")
  referredBy             String?
  inviteToken            String?
  verifiedBy             String?
  verifiedAt             DateTime?
  opsRemarks             String?
  financeApprovedBy      String?
  financeApprovedAt      DateTime?
  paymentRemarks         String?
  paymentProof           Json?
  credentials            Json?
  statusHistory          Json                @default("[]")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  admissionSessions      AdmissionSession[]
  enrollments            Enrollment[]
  enrollmentPayments     EnrollmentPayment[]
  internalMarks          InternalMark[]
  invoices               Invoice[]
  programAllocations     ProgramAllocation[]
  sessionRequests        SessionRequest[]
  students               Student[]
  approver               User?               @relation("FinanceApprovedBy", fields: [financeApprovedBy], references: [id])
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  referrer               User?               @relation("ReferredBy", fields: [referredBy], references: [id])
  verifier               User?               @relation("VerifiedBy", fields: [verifiedBy], references: [id])
  wallet                 StudyCenterWallet?
  targets                Target[]
  centerAdmins           User[]              @relation("CenterAdmin")
  walletTopUps           WalletTopUp[]
  allowedPrograms        Program[]           @relation("ProgramToStudyCenter")
  assignedSubDepts       SubDepartment[]     @relation("SubDeptToCenter")
  associatedUniversities University[]        @relation("UniversityToStudyCenter")

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Student {
  id             String         @id @default(uuid())
  centerId       String
  organizationId String
  enrollmentNo   String         @unique
  name           String
  email          String         @unique
  phone          String
  address        String
  programId      String
  sessionId      String?
  status         String         @default("pending")
  joinDate       DateTime       @default(now())
  enrolledAt     DateTime?
  reregStatus    Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  referredBy     String?
  enrollments    Enrollment[]
  internalMarks  InternalMark[]
  invoices       Invoice[]
  center         StudyCenter    @relation(fields: [centerId], references: [id])
  user           User           @relation(fields: [email], references: [email])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program        Program        @relation(fields: [programId], references: [id])
  referrer       User?          @relation("StudentReferredBy", fields: [referredBy], references: [id])

  @@index([organizationId, status])
  @@index([centerId])
  @@index([referredBy])
}

model Invoice {
  id             String         @id @default(uuid())
  organizationId String
  centerId       String
  studentId      String?
  invoiceNo      String         @unique
  amount         Float
  tax            Float          @default(0)
  total          Float
  status         String         @default("draft")
  items          Json           @default("[]")
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  center         StudyCenter    @relation(fields: [centerId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student?       @relation(fields: [studentId], references: [id])
  payments       PaymentEntry[]

  @@index([organizationId, status])
  @@index([centerId])
}

model Lead {
  id             String       @id @default(uuid())
  organizationId String
  centerName     String
  contactName    String
  email          String
  phone          String
  address        String
  source         String
  referredBy     String?
  status         String       @default("new")
  notes          String       @default("")
  convertedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  referrer       User?        @relation("LeadReferredBy", fields: [referredBy], references: [id])

  @@index([organizationId, status])
  @@index([referredBy])
}

model Complaint {
  id             String            @id @default(uuid())
  organizationId String
  employeeId     String
  subject        String
  description    String
  category       String
  status         ComplaintStatus   @default(open)
  priority       ComplaintPriority @default(medium)
  submittedAt    DateTime          @default(now())
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [employeeId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([employeeId])
}

model Notification {
  id             String               @id @default(uuid())
  organizationId String
  userId         String
  title          String
  message        String
  type           NotificationType     @default(general)
  priority       NotificationPriority @default(medium)
  read           Boolean              @default(false)
  link           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  action         String
  entityType     String
  entityId       String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  timestamp      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, timestamp(sort: Desc)])
  @@index([userId])
  @@index([entityType, entityId])
}

model Announcement {
  id             String            @id @default(uuid())
  organizationId String
  departmentId   String?
  title          String
  content        String
  type           String            @default("general")
  priority       ComplaintPriority @default(medium)
  postedBy       String
  postedAt       DateTime          @default(now())
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  department     Department?       @relation(fields: [departmentId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User              @relation(fields: [postedBy], references: [id])

  @@index([organizationId, postedAt(sort: Desc)])
  @@index([departmentId])
}

model Holiday {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  date           DateTime
  type           String       @default("public")
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
}

model LeaveRequest {
  id               String       @id @default(uuid())
  employeeId       String
  organizationId   String
  departmentId     String
  type             LeaveType
  startDate        DateTime
  endDate          DateTime
  reason           String
  status           LeaveStatus  @default(pending)
  deptAdminRemarks String?
  hrRemarks        String?
  deptApprovedBy   String?
  hrApprovedBy     String?
  appliedAt        DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  department       Department   @relation(fields: [departmentId], references: [id])
  deptApprover     User?        @relation("DeptApprovedBy", fields: [deptApprovedBy], references: [id])
  user             User         @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  hrApprover       User?        @relation("HrApprovedBy", fields: [hrApprovedBy], references: [id])
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([organizationId, status])
}

model SalaryConfig {
  id                     String         @id @default(uuid())
  organizationId         String
  userId                 String         @unique
  basicSalary            Float
  allowances             Json?          @default("{}")
  deductions             Json?          @default("{}")
  lateDeductionPerMinute Float?         @default(0)
  approvalStatus         ApprovalStatus @default(pending_approval)
  approvedBy             String?
  approvedAt             DateTime?
  rejectedRemarks        String?
  createdBy              String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  approver               User?          @relation("SalaryApprovedBy", fields: [approvedBy], references: [id])
  creator                User?          @relation("SalaryCreatedBy", fields: [createdBy], references: [id])
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User           @relation("UserSalaryConfig", fields: [userId], references: [id])

  @@index([organizationId])
}

model Payroll {
  id                     String         @id @default(uuid())
  organizationId         String
  employeeId             String
  month                  String
  basicSalary            Float
  allowances             Json?
  deductions             Json?
  bonus                  Float?         @default(0)
  overtime               Float?         @default(0)
  grossSalary            Float
  netSalary              Float
  status                 PayrollStatus  @default(draft)
  confirmedBy            String?
  confirmedAt            DateTime?
  transferredToFinanceBy String?
  transferredToFinanceAt DateTime?
  financeApprovedBy      String?
  financeApprovedAt      DateTime?
  paymentDate            DateTime?
  paymentMethod          PaymentMethod?
  paymentReference       String?
  processedBy            String?
  processedAt            DateTime?
  remarks                String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  confirmer              User?          @relation("PayrollConfirmedBy", fields: [confirmedBy], references: [id])
  user                   User           @relation("EmployeePayroll", fields: [employeeId], references: [id])
  financeApprover        User?          @relation("PayrollFinanceApprovedBy", fields: [financeApprovedBy], references: [id])
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processor              User?          @relation("PayrollProcessedBy", fields: [processedBy], references: [id])
  transferer             User?          @relation("PayrollTransferredBy", fields: [transferredToFinanceBy], references: [id])

  @@unique([employeeId, month])
  @@index([organizationId, month])
  @@index([status])
}

model Branch {
  id                String              @id @default(uuid())
  organizationId    String
  name              String
  code              String              @unique
  city              String?
  address           String?
  contact           String?
  status            String              @default("active")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  branchManagerId   String?             @unique
  salesDeptId       String?             @unique
  operationsDeptId  String?             @unique
  additionalDeptIds Json?               @default("[]")
  branchManager     User?               @relation("BranchManager", fields: [branchManagerId], references: [id])
  operationsDept    Department?         @relation("BranchOpsDept", fields: [operationsDeptId], references: [id])
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDept         Department?         @relation("BranchSalesDept", fields: [salesDeptId], references: [id])
  designations      Designation[]
  invites           StudyCenterInvite[]
  users             User[]
  universities      University[]        @relation("UniversityToBranch")

  @@unique([organizationId, code])
  @@index([organizationId])
}

model SubDepartment {
  id                   String             @id @default(uuid())
  organizationId       String
  parentDeptId         String
  name                 String
  type                 String
  features             Json?              @default("[]")
  status               String             @default("active")
